{
  "name": "mise",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.14-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "installTools": false
    },
    "ghcr.io/devcontainers-extra/features/mise:1": {}
  },
  "postCreateCommand": "bash -lc 'mise trust && mise install'",
  "customizations": {
    "vscode": {
      "extensions": [
        "hverlin.mise-vscode"
      ]
    }
  },
  "mounts": [],
  "containerEnv": {},
  "remoteEnv": {}
}